{
  "name": "oil-painting-app-beta",
  "alias": ["oil-painting-beta.vercel.app"],
  "env": {
    "NEXT_PUBLIC_ENVIRONMENT": "beta",
    "NEXT_PUBLIC_GA_MEASUREMENT_ID": "@ga_measurement_id_beta",
    "NEXT_PUBLIC_SITE_URL": "https://oil-painting-beta.vercel.app",
    "GEMINI_API_KEY": "@gemini_api_key",
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key",
    "NEXT_PUBLIC_SUPABASE_URL": "@supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@supabase_anon_key"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_ENVIRONMENT": "beta"
    }
  },
  "functions": {
    "app/api/convert-hybrid/route.ts": {
      "maxDuration": 60
    },
    "app/api/convert-v3/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Environment",
          "value": "beta"
        }
      ]
    }
  ]
}
