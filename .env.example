# PetCanvas Environment Variables Template
# Copy this to .env.local and fill in your values

# NextAuth Configuration
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXTAUTH_URL=http://localhost:5174

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SITE_URL=http://localhost:5174

# AI Model APIs
A1111_BASE_URL=http://localhost:7860
COMFYUI_BASE_URL=http://localhost:8188
USE_CLOUD_FALLBACK=true

# Social Authentication (OAuth)
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_app_id  
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# Apple OAuth
APPLE_ID=com.petcanvas.webapp.service
APPLE_SECRET=your_jwt_secret

# Firebase (Database)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="your_firebase_private_key"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Optional: Slack Notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Optional: Stripe (Future payments)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx