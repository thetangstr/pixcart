{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/convert-hybrid/route.ts": {
      "maxDuration": 60
    },
    "app/api/convert-v3/route.ts": {
      "maxDuration": 60
    },
    "app/api/convert-enhanced/route.ts": {
      "maxDuration": 60
    }
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1",
    "SKIP_FIREBASE_INIT": "true"
  }
}
